generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Gender {
  Male
  Female
}

enum MeetingPreference {
  Online
  Hybrid
  InPerson
}

enum GenderFocus {
  Male
  Female
  Mixed
}

enum MeetingFormat {
  Online
  Hybrid
  InPerson
}

enum VolunteerStatus {
  Pending
  Confirmed
  Rejected
}

enum EventType {
  OneTime
  MultiDay
  Recurring
}

enum RecurrenceFrequency {
  Weekly
  Biweekly
  Monthly
}

enum MatchingContext {
  SmallGroup
  Breakout
}

enum EventModuleType {
  Baptism
  Embarkation
  CatchMech
}

enum DietaryPreference {
  Vegetarian
  Vegan
  Halal
  Kosher
  GlutenFree
  DairyFree
  NutFree
  Pescatarian
  Other
}

enum MemberGroupStatus {
  Member
  Timothy
  Leader
}

enum FamilyRole {
  Father
  Mother
  Child
  Guardian
  Other
}

enum BusDirection {
  ToVenue
  FromVenue
  Both
}

enum MemberRequestStatus {
  Pending
  Confirmed
  Rejected
}

enum DeclineReason {
  NotInterested
  Unresponsive
  EndorsedToAnotherLeader
  AlreadyInSmallGroup
  Others
}

enum SmallGroupLogAction {
  GroupCreated
  MemberAdded
  MemberRemoved
  MemberTransferred
  TempAssignmentCreated
  TempAssignmentConfirmed
  TempAssignmentRejected
}

enum SmallGroupStatus {
  Active
  Pending
  Inactive
}

enum SmallGroupType {
  Regular
  Couples
}

enum UserRole {
  SuperAdmin
  Staff
}

enum FeatureArea {
  Members
  Guests
  SmallGroups
  Ministries
  Events
  Volunteers
  Forms
}

enum FormKey {
  JoinSmallGroup
  MemberSelfService
  SmallGroupConfirmation
  EventRegistration
  VolunteerSignUp
  VolunteerInfo
  VolunteerApproval
  CatchMech
}

enum PermissionAction {
  Read
  Write
  Import
  Export
}

// ─── Auth (NextAuth / Auth.js v5) ────────────────────────────────────────────

model User {
  id                String           @id @default(cuid())
  name              String?
  username          String           @unique
  email             String?          @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  tempPassword      String?
  role              UserRole         @default(Staff)
  mustChangePassword Boolean         @default(false)
  requiresTotpSetup Boolean          @default(false)
  totpSecret        String?
  totpEnabled       Boolean          @default(false)
  accounts          Account[]
  sessions          Session[]
  permissions       UserPermission[]
  eventAccess       UserEventAccess[]
  groupRequests     SmallGroupMemberRequest[]
  smallGroupLogs    SmallGroupLog[]
  catchMechComments CatchMechComment[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model UserPermission {
  id      String           @id @default(cuid())
  userId  String
  feature FeatureArea
  action  PermissionAction @default(Read)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature, action])
}

model UserEventAccess {
  userId  String
  eventId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── App Models ──────────────────────────────────────────────────────────────

model LifeStage {
  id          String     @id @default(cuid())
  name        String     @unique
  order       Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  members        Member[]
  guests         Guest[]
  ministries     Ministry[]
  smallGroups    SmallGroup[]    @relation("SmallGroupLifeStages")
  breakoutGroups BreakoutGroup[] @relation("BreakoutGroupLifeStages")
}

model Member {
  id                  String              @id @default(cuid())
  firstName           String
  lastName            String
  nickname            String?
  email               String?             @unique
  phone               String?
  address             String?
  dateJoined          DateTime
  notes               String?

  lifeStageId         String?
  lifeStage           LifeStage?          @relation(fields: [lifeStageId], references: [id])

  smallGroupId        String?
  smallGroup          SmallGroup?         @relation("SmallGroupMembers", fields: [smallGroupId], references: [id])
  groupStatus         MemberGroupStatus?  // null when not in a group; set when member joins

  // Matching fields
  gender              Gender?
  language            String[]
  birthMonth          Int?
  birthYear           Int?
  workCity            String?
  workIndustry        String?
  meetingPreference   MeetingPreference?

  // Self-service token for the public /me member portal link
  selfServiceToken    String?             @unique

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  ledGroups           SmallGroup[]        @relation("SmallGroupLeader")
  schedulePreferences SchedulePreference[]
  volunteers          Volunteer[]
  eventRegistrations  EventRegistrant[]
  guest               Guest?              // set if this Member was promoted from a Guest
  groupRequests       SmallGroupMemberRequest[]
  smallGroupLogs      SmallGroupLog[]
  logs                MemberLog[]
  familyMemberships   FamilyMember[]
}

model Guest {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  nickname    String?
  email       String?
  phone       String?
  notes       String?

  // Matching fields (same set as Member — used for SmallGroup placement)
  lifeStageId      String?
  lifeStage        LifeStage?        @relation(fields: [lifeStageId], references: [id])
  gender           Gender?
  language         String[]
  birthMonth       Int?
  birthYear        Int?
  workCity         String?
  workIndustry     String?
  meetingPreference MeetingPreference?

  // Single schedule preference (one time slot per guest — mirrors SmallGroup pattern)
  scheduleDayOfWeek Int?     // 0 = Sunday … 6 = Saturday
  scheduleTimeStart String?  // HH:MM
  scheduleTimeEnd   String?  // HH:MM

  // Self-reported small group from check-in prompt
  claimedSmallGroupId String?
  claimedSmallGroup   SmallGroup? @relation("GuestClaimedGroup", fields: [claimedSmallGroupId], references: [id])

  // Promotion — set when Guest is added to a Small Group and becomes a Member
  memberId    String?  @unique
  member      Member?  @relation(fields: [memberId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventRegistrations EventRegistrant[]
  groupRequests      SmallGroupMemberRequest[]
  smallGroupLogs     SmallGroupLog[]
  familyMemberships  FamilyMember[]
}

// ─── Families ─────────────────────────────────────────────────────────────────
// A Family is a household unit. A person can belong to multiple families
// (e.g. an adult is a Child in their parents' family and a Father in their own),
// hence the join model rather than a familyId column on Member.

model Family {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members FamilyMember[]
}

model FamilyMember {
  id       String     @id @default(cuid())
  familyId String
  family   Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)

  // Exactly one of memberId / guestId is set (app-layer enforced, same idiom
  // as SmallGroupMemberRequest). Repointed guestId → memberId on promotion.
  memberId String?
  member   Member?    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  guestId  String?
  guest    Guest?     @relation(fields: [guestId], references: [id], onDelete: Cascade)

  role      FamilyRole
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([familyId, memberId])
  @@unique([familyId, guestId])
  @@index([memberId])
  @@index([guestId])
}

model SchedulePreference {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0 = Sunday, 6 = Saturday
  timeStart String   // HH:MM
  timeEnd   String?  // HH:MM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmallGroup {
  id            String         @id @default(cuid())
  name          String
  leaderId      String?
  leader        Member?        @relation("SmallGroupLeader", fields: [leaderId], references: [id])
  parentGroupId String?
  parentGroup   SmallGroup?    @relation("SmallGroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups   SmallGroup[]   @relation("SmallGroupHierarchy")

  // Matching fields
  lifeStages    LifeStage[]    @relation("SmallGroupLifeStages")
  genderFocus   GenderFocus?
  language      String[]
  ageRangeMin   Int?
  ageRangeMax   Int?
  meetingFormat MeetingFormat?
  locationCity  String?
  memberLimit   Int?

  // Single meeting schedule (one time slot per group)
  scheduleDayOfWeek Int?     // 0 = Sunday … 6 = Saturday
  scheduleTimeStart String?  // HH:MM
  scheduleTimeEnd   String?  // HH:MM

  // Leader confirmation token for the public confirmation link
  leaderConfirmationToken String?  @unique

  status           SmallGroupStatus     @default(Active)
  // Couples groups roster married pairs (derived from Family data); membership
  // is still individual and one-group-per-member applies unchanged.
  groupType        SmallGroupType       @default(Regular)

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  members          Member[]             @relation("SmallGroupMembers")
  claimants        Guest[]              @relation("GuestClaimedGroup")
  memberRequests   SmallGroupMemberRequest[]
  incomingTransfers SmallGroupMemberRequest[] @relation("TransferFrom")
  logs             SmallGroupLog[]
  linkedBreakoutGroups BreakoutGroup[]  @relation("BreakoutLinkedGroup")
}

model Ministry {
  id                  String     @id @default(cuid())
  name                String     @unique
  lifeStageId         String?
  lifeStage           LifeStage? @relation(fields: [lifeStageId], references: [id])
  description         String?
  // Branding
  logoUrl             String?
  themeColorPrimary   String?
  themeColorSecondary String?
  themeColorAccent    String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  events EventMinistry[]
}

model Event {
  id                    String              @id @default(cuid())
  name                  String
  description           String?
  type                  EventType           @default(OneTime)
  startDate             DateTime
  endDate               DateTime
  price                 Int?                // in cents; null = free
  registrationStart     DateTime?
  registrationEnd       DateTime?
  // Recurring-only fields
  recurrenceDayOfWeek   Int?                // 0 = Sunday … 6 = Saturday
  recurrenceFrequency   RecurrenceFrequency?
  recurrenceEndDate     DateTime?           // null = runs indefinitely
  // Branding
  useMinistryBrand      Boolean             @default(false)
  brandMinistryId       String?
  logoUrl               String?
  themeColorPrimary     String?
  themeColorSecondary   String?
  themeColorAccent      String?
  // Registration form modules — toggle which optional sections appear on the public form
  formIncludeSmallGroup       Boolean             @default(false)
  formIncludeDietary          Boolean             @default(false)
  formIncludePayment          Boolean             @default(false)
  autoAssignBreakout          Boolean             @default(false)
  // Registration page customization
  registrationPageTitle       String?
  registrationPageDescription String?
  registrationPageBannerUrl   String?
  // Setup walkthrough — once the admin dismisses the dashboard setup checklist it stays hidden
  setupDismissedAt            DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  ministries     EventMinistry[]
  registrants    EventRegistrant[]
  occurrences    EventOccurrence[]
  occurrenceSeries EventOccurrenceSeries[]
  breakoutGroups BreakoutGroup[]
  committees     VolunteerCommittee[]
  volunteers     Volunteer[]
  modules        EventModule[]
  baptismOptIns  BaptismOptIn[]
  buses             Bus[]
  userAccess        UserEventAccess[]
  catchMechSessions CatchMechSession[]
  memberLogs        MemberLog[]
  formConfigs       FormConfig[]
}

model EventMinistry {
  eventId    String
  ministryId String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ministry   Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([eventId, ministryId])
}

model EventOccurrenceSeries {
  id         String            @id @default(cuid())
  eventId     String
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  occurrences EventOccurrence[]

  @@index([eventId, startDate, endDate])
}

model EventOccurrence {
  id        String               @id @default(cuid())
  eventId   String
  event     Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seriesId  String?
  series    EventOccurrenceSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  date      DateTime
  notes     String?
  isOpen    Boolean              @default(false)
  isStandalone Boolean           @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  attendees        OccurrenceAttendee[]
  subFacilitators  OccurrenceSubFacilitator[]

  @@unique([eventId, date])
  @@index([seriesId])
}

model OccurrenceAttendee {
  id           String          @id @default(cuid())
  occurrenceId String
  occurrence   EventOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  // Exactly one of registrantId / volunteerId is set (app-layer enforced), mirroring the
  // EventRegistrant memberId/guestId convention. A volunteer is never a registrant.
  registrantId String?
  registrant   EventRegistrant? @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  volunteerId  String?
  volunteer    Volunteer?       @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  checkedInAt  DateTime        @default(now())

  @@unique([occurrenceId, registrantId])
  @@unique([occurrenceId, volunteerId])
}

enum FacilitatorRole {
  Facilitator
  CoFacilitator
}

model OccurrenceSubFacilitator {
  id              String          @id @default(cuid())
  occurrenceId    String
  occurrence      EventOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  breakoutGroupId String
  breakoutGroup   BreakoutGroup   @relation(fields: [breakoutGroupId], references: [id], onDelete: Cascade)
  role            FacilitatorRole
  substituteId    String
  substitute      Volunteer       @relation(fields: [substituteId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())

  @@unique([occurrenceId, breakoutGroupId, role])
}

model EventRegistrant {
  id           String    @id @default(cuid())
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  memberId     String?
  member       Member?   @relation(fields: [memberId], references: [id])

  guestId      String?
  guest        Guest?    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  // Only populated when both memberId and guestId are null (truly anonymous registrant)
  firstName    String?
  lastName     String?
  nickname     String?
  email        String?
  mobileNumber String?

  isPaid           Boolean   @default(false)
  paymentReference String?
  // Dietary restrictions — populated when the event's registration form has the Dietary module enabled
  dietaryPreference DietaryPreference?
  dietaryOther      String?
  attendedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  breakoutGroupMemberships BreakoutGroupMember[]
  baptismOptIn             BaptismOptIn?
  busPassengers            BusPassenger[]
  occurrenceAttendances    OccurrenceAttendee[]
}

model BreakoutGroup {
  id            String       @id @default(cuid())
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  facilitatorId   String?
  facilitator     Volunteer?   @relation("FacilitatedGroups", fields: [facilitatorId], references: [id])
  coFacilitatorId String?
  coFacilitator   Volunteer?   @relation("CoFacilitatedGroups", fields: [coFacilitatorId], references: [id])

  // Matching fields (mirrors SmallGroup)
  lifeStages    LifeStage[]  @relation("BreakoutGroupLifeStages")
  genderFocus   GenderFocus?
  language      String[]
  ageRangeMin   Int?
  ageRangeMax   Int?
  meetingFormat MeetingFormat?
  locationCity  String?
  memberLimit   Int?

  // Linked small group for temp-membership assignment on registrant assignment
  linkedSmallGroupId String?
  linkedSmallGroup   SmallGroup? @relation("BreakoutLinkedGroup", fields: [linkedSmallGroupId], references: [id], onDelete: SetNull)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  members           BreakoutGroupMember[]
  schedules         BreakoutGroupSchedule[]
  catchMechSessions CatchMechSession[]
  subFacilitators   OccurrenceSubFacilitator[]
}

model BreakoutGroupSchedule {
  id              String        @id @default(cuid())
  breakoutGroupId String
  breakoutGroup   BreakoutGroup @relation(fields: [breakoutGroupId], references: [id], onDelete: Cascade)
  dayOfWeek       Int           // 0 = Sunday, 6 = Saturday
  timeStart       String        // HH:MM
  timeEnd         String?       // HH:MM
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BreakoutGroupMember {
  breakoutGroupId String
  breakoutGroup   BreakoutGroup   @relation(fields: [breakoutGroupId], references: [id], onDelete: Cascade)
  registrantId    String
  registrant      EventRegistrant @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  assignedAt      DateTime        @default(now())

  @@id([breakoutGroupId, registrantId])
}

model VolunteerCommittee {
  id        String   @id @default(cuid())
  name      String
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles      CommitteeRole[]
  volunteers Volunteer[]
}

model CommitteeRole {
  id          String             @id @default(cuid())
  name        String
  committeeId String
  committee   VolunteerCommittee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  preferredByVolunteers Volunteer[] @relation("PreferredRole")
  assignedToVolunteers  Volunteer[] @relation("AssignedRole")
}

model Volunteer {
  id              String             @id @default(cuid())
  memberId        String
  member          Member             @relation(fields: [memberId], references: [id])
  eventId         String
  event           Event              @relation(fields: [eventId], references: [id])
  committeeId     String
  committee       VolunteerCommittee @relation(fields: [committeeId], references: [id])
  preferredRoleId String
  preferredRole   CommitteeRole      @relation("PreferredRole", fields: [preferredRoleId], references: [id])
  assignedRoleId  String?
  assignedRole    CommitteeRole?     @relation("AssignedRole", fields: [assignedRoleId], references: [id])
  status               VolunteerStatus    @default(Pending)
  notes                String?
  leaderApprovalToken  String?           @unique
  leaderNotes          String?
  // OneTime-event attendance marker, symmetric to EventRegistrant.attendedAt.
  // Session-based (MultiDay/Recurring) attendance lives in OccurrenceAttendee.
  attendedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  facilitatedGroups     BreakoutGroup[] @relation("FacilitatedGroups")
  coFacilitatedGroups   BreakoutGroup[] @relation("CoFacilitatedGroups")
  busPassengers         BusPassenger[]
  catchMechSessions     CatchMechSession[]
  declinedRequests      SmallGroupMemberRequest[] @relation("DeclinedRequests")
  subFacilitatorSlots   OccurrenceSubFacilitator[]
  occurrenceAttendances OccurrenceAttendee[]
}

model MatchingWeightConfig {
  id        String          @id @default(cuid())
  context   MatchingContext @unique
  lifeStage Float
  gender    Float
  language  Float
  age       Float
  schedule  Float
  location  Float
  mode      Float
  career    Float
  capacity  Float
  // Days a group is excluded from guest match suggestions after receiving a
  // guest assignment (0 = disabled). Only meaningful on the SmallGroup row.
  guestCooldownDays Int      @default(7)
  updatedAt DateTime        @updatedAt
}

// ─── Event Add-on Modules ─────────────────────────────────────────────────────

model EventModule {
  id        String          @id @default(cuid())
  eventId   String
  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type      EventModuleType
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([eventId, type])
}

model BaptismOptIn {
  id           String          @id @default(cuid())
  eventId      String
  event        Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrantId String          @unique  // one baptism per registrant globally (across all events)
  registrant   EventRegistrant @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@unique([eventId, registrantId])
}

model Bus {
  id        String       @id @default(cuid())
  eventId   String
  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  capacity  Int?         // null = unlimited
  direction BusDirection @default(ToVenue)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  passengers BusPassenger[]
}

model BusPassenger {
  id           String           @id @default(cuid())
  busId        String
  bus          Bus              @relation(fields: [busId], references: [id], onDelete: Cascade)
  registrantId String?
  registrant   EventRegistrant? @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  volunteerId  String?
  volunteer    Volunteer?       @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  // Exactly one of registrantId or volunteerId must be set (enforced at app layer)
}

// ─── Small Group Member Requests & Logs ──────────────────────────────────────

model SmallGroupMemberRequest {
  id           String              @id @default(cuid())
  // Null only for a groupless decline: a Timothy who leads no group yet declines
  // someone, so there is no group to scope the rejection to. Every other request
  // (Pending, Confirmed, and any decline by a faci who leads a group) sets this.
  smallGroupId String?
  smallGroup   SmallGroup?         @relation(fields: [smallGroupId], references: [id], onDelete: Cascade)

  // Exactly one of guestId or memberId must be set (enforced at app layer)
  guestId      String?
  guest        Guest?              @relation(fields: [guestId], references: [id], onDelete: Cascade)
  memberId     String?
  member       Member?             @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // For member transfers: record the source group at request time
  fromGroupId  String?
  fromGroup    SmallGroup?         @relation("TransferFrom", fields: [fromGroupId], references: [id])

  status       MemberRequestStatus @default(Pending)
  // Structured rejection reason (analytics-friendly); notes holds free text for Others
  declineReason DeclineReason?
  notes        String?

  assignedByUserId String?
  assignedByUser   User?           @relation(fields: [assignedByUserId], references: [id])

  // Tracks which breakout group triggered this request (for auto-cancellation on removal)
  breakoutGroupId  String?

  // The faci who declined via Catch Mech. Only needed to scope a groupless decline
  // (smallGroupId = null) to its author — lead and co-faci share a breakout group,
  // so breakoutGroupId alone cannot tell their lists apart.
  declinedByVolunteerId String?
  declinedByVolunteer   Volunteer? @relation("DeclinedRequests", fields: [declinedByVolunteerId], references: [id], onDelete: SetNull)

  comments     CatchMechComment[]

  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())
}

model SmallGroupLog {
  id           String              @id @default(cuid())
  smallGroupId String
  smallGroup   SmallGroup          @relation(fields: [smallGroupId], references: [id], onDelete: Cascade)
  action       SmallGroupLogAction

  // Subject (who was affected)
  memberId     String?
  member       Member?             @relation(fields: [memberId], references: [id])
  guestId      String?
  guest        Guest?              @relation(fields: [guestId], references: [id])

  // Transfer metadata
  fromGroupId  String?
  toGroupId    String?

  // Actor
  performedByUserId String?
  performedByUser   User?          @relation(fields: [performedByUserId], references: [id])

  description  String?
  createdAt    DateTime            @default(now())
}

model MemberLog {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  action      String
  description String?
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

// ─── Catch Mech ──────────────────────────────────────────────────────────────

model CatchMechSession {
  id                     String        @id @default(cuid())
  token                  String        @unique @default(cuid())
  eventId                String
  event                  Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  breakoutGroupId        String
  breakoutGroup          BreakoutGroup @relation(fields: [breakoutGroupId], references: [id], onDelete: Cascade)
  facilitatorVolunteerId String
  facilitator            Volunteer     @relation(fields: [facilitatorVolunteerId], references: [id], onDelete: Cascade)
  createdAt              DateTime      @default(now())
}

model CatchMechComment {
  id        String                  @id @default(cuid())
  requestId String
  request   SmallGroupMemberRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  author    User                    @relation(fields: [authorId], references: [id])
  text      String
  createdAt DateTime                @default(now())
}

// ─── Site Settings ────────────────────────────────────────────────────────────

model SiteSettings {
  id                          String   @id @default("singleton")
  joinPageTitle               String   @default("Find Your Small Group")
  joinPageDescription         String   @default("Tell us about yourself and we'll suggest the best small groups for you.")
  joinPageLogoUrl             String   @default("")
  joinPageBackgroundImageUrl  String   @default("")
  joinPageAccentColor         String   @default("")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

// ─── Form Config ──────────────────────────────────────────────────────────────
// Per-form public-access (open/closed) + theme overrides. One row per form:
// global forms key on "global:<FormKey>"; event forms on "<eventId>:<FormKey>".
model FormConfig {
  id           String   @id @default(cuid())
  scopeKey     String   @unique
  key          FormKey
  eventId      String?
  event        Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  isOpen       Boolean  @default(true)
  // per-form theme overrides (all optional → fall back to scope defaults)
  title        String?
  description  String?
  logoUrl      String?
  bannerUrl    String?
  primaryColor String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
}
