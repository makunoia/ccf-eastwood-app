generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Gender {
  Male
  Female
}

enum MeetingPreference {
  Online
  Hybrid
  InPerson
}

enum GenderFocus {
  Male
  Female
  Mixed
}

enum MeetingFormat {
  Online
  Hybrid
  InPerson
}

enum VolunteerStatus {
  Pending
  Confirmed
  Rejected
}

enum EventType {
  OneTime
  MultiDay
  Recurring
}

enum RecurrenceFrequency {
  Weekly
  Biweekly
  Monthly
}

enum MatchingContext {
  SmallGroup
  Breakout
}

enum EventModuleType {
  Baptism
  Embarkation
}

enum BusDirection {
  ToVenue
  FromVenue
  Both
}

enum UserRole {
  SuperAdmin
  Staff
}

enum FeatureArea {
  Members
  Guests
  SmallGroups
  Ministries
  Events
  Volunteers
}

// ─── Auth (NextAuth / Auth.js v5) ────────────────────────────────────────────

model User {
  id                String           @id @default(cuid())
  name              String?
  email             String           @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              UserRole         @default(Staff)
  mustChangePassword Boolean         @default(false)
  requiresTotpSetup Boolean          @default(false)
  totpSecret        String?
  totpEnabled       Boolean          @default(false)
  accounts          Account[]
  sessions          Session[]
  permissions       UserPermission[]
  eventAccess       UserEventAccess[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model UserPermission {
  id      String      @id @default(cuid())
  userId  String
  feature FeatureArea
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature])
}

model UserEventAccess {
  userId  String
  eventId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── App Models ──────────────────────────────────────────────────────────────

model LifeStage {
  id          String     @id @default(cuid())
  name        String     @unique
  order       Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  members        Member[]
  guests         Guest[]
  ministries     Ministry[]
  smallGroups    SmallGroup[]
  breakoutGroups BreakoutGroup[]
}

model Member {
  id                  String              @id @default(cuid())
  firstName           String
  lastName            String
  email               String?             @unique
  phone               String?
  address             String?
  dateJoined          DateTime
  notes               String?

  lifeStageId         String?
  lifeStage           LifeStage?          @relation(fields: [lifeStageId], references: [id])

  smallGroupId        String?
  smallGroup          SmallGroup?         @relation("SmallGroupMembers", fields: [smallGroupId], references: [id])
  smallGroupStatusId  String?
  smallGroupStatus    SmallGroupStatus?   @relation(fields: [smallGroupStatusId], references: [id])

  // Matching fields
  gender              Gender?
  language            String[]
  birthDate           DateTime?
  workCity            String?
  workIndustry        String?
  meetingPreference   MeetingPreference?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  ledGroups           SmallGroup[]        @relation("SmallGroupLeader")
  schedulePreferences SchedulePreference[]
  volunteers          Volunteer[]
  eventRegistrations  EventRegistrant[]
  guest               Guest?              // set if this Member was promoted from a Guest
}

model Guest {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  notes       String?

  // Matching fields (same set as Member — used for SmallGroup placement)
  lifeStageId      String?
  lifeStage        LifeStage?        @relation(fields: [lifeStageId], references: [id])
  gender           Gender?
  language         String[]
  birthDate        DateTime?
  workCity         String?
  workIndustry     String?
  meetingPreference MeetingPreference?

  // Single schedule preference (one time slot per guest — mirrors SmallGroup pattern)
  scheduleDayOfWeek Int?     // 0 = Sunday … 6 = Saturday
  scheduleTimeStart String?  // HH:MM
  scheduleTimeEnd   String?  // HH:MM

  // Self-reported small group from check-in prompt
  claimedSmallGroupId String?
  claimedSmallGroup   SmallGroup? @relation("GuestClaimedGroup", fields: [claimedSmallGroupId], references: [id])

  // Promotion — set when Guest is added to a Small Group and becomes a Member
  memberId    String?  @unique
  member      Member?  @relation(fields: [memberId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventRegistrations EventRegistrant[]
}

model SchedulePreference {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0 = Sunday, 6 = Saturday
  timeStart String   // HH:MM
  timeEnd   String   // HH:MM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmallGroup {
  id            String         @id @default(cuid())
  name          String
  leaderId      String
  leader        Member         @relation("SmallGroupLeader", fields: [leaderId], references: [id])
  parentGroupId String?
  parentGroup   SmallGroup?    @relation("SmallGroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups   SmallGroup[]   @relation("SmallGroupHierarchy")

  // Matching fields
  lifeStageId   String?
  lifeStage     LifeStage?     @relation(fields: [lifeStageId], references: [id])
  genderFocus   GenderFocus?
  language      String[]
  ageRangeMin   Int?
  ageRangeMax   Int?
  meetingFormat MeetingFormat?
  locationCity  String?
  memberLimit   Int?

  // Single meeting schedule (one time slot per group)
  scheduleDayOfWeek Int?     // 0 = Sunday … 6 = Saturday
  scheduleTimeStart String?  // HH:MM
  scheduleTimeEnd   String?  // HH:MM

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  members   Member[]   @relation("SmallGroupMembers")
  claimants Guest[]    @relation("GuestClaimedGroup")
}

model SmallGroupStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Member[]
}


model Ministry {
  id          String     @id @default(cuid())
  name        String     @unique
  lifeStageId String?
  lifeStage   LifeStage? @relation(fields: [lifeStageId], references: [id])
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  events     EventMinistry[]
  committees VolunteerCommittee[]
  volunteers Volunteer[]
}

model Event {
  id                    String              @id @default(cuid())
  name                  String
  description           String?
  type                  EventType           @default(OneTime)
  startDate             DateTime
  endDate               DateTime
  price                 Int?                // in cents; null = free
  registrationStart     DateTime?
  registrationEnd       DateTime?
  // Recurring-only fields
  recurrenceDayOfWeek   Int?                // 0 = Sunday … 6 = Saturday
  recurrenceFrequency   RecurrenceFrequency?
  recurrenceEndDate     DateTime?           // null = runs indefinitely
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  ministries     EventMinistry[]
  registrants    EventRegistrant[]
  occurrences    EventOccurrence[]
  breakoutGroups BreakoutGroup[]
  committees     VolunteerCommittee[]
  volunteers     Volunteer[]
  modules        EventModule[]
  baptismOptIns  BaptismOptIn[]
  buses          Bus[]
  userAccess     UserEventAccess[]
}

model EventMinistry {
  eventId    String
  ministryId String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ministry   Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([eventId, ministryId])
}

model EventOccurrence {
  id        String               @id @default(cuid())
  eventId   String
  event     Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date      DateTime
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  attendees OccurrenceAttendee[]

  @@unique([eventId, date])
}

model OccurrenceAttendee {
  id           String          @id @default(cuid())
  occurrenceId String
  occurrence   EventOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  registrantId String
  registrant   EventRegistrant @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  checkedInAt  DateTime        @default(now())

  @@unique([occurrenceId, registrantId])
}

model EventRegistrant {
  id           String    @id @default(cuid())
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  memberId     String?
  member       Member?   @relation(fields: [memberId], references: [id])

  guestId      String?
  guest        Guest?    @relation(fields: [guestId], references: [id])

  // Only populated when both memberId and guestId are null (truly anonymous registrant)
  firstName    String?
  lastName     String?
  nickname     String?
  email        String?
  mobileNumber String?

  isPaid           Boolean   @default(false)
  paymentReference String?
  attendedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  breakoutGroupMemberships BreakoutGroupMember[]
  baptismOptIn             BaptismOptIn?
  busPassengers            BusPassenger[]
  occurrenceAttendances    OccurrenceAttendee[]
}

model BreakoutGroup {
  id            String       @id @default(cuid())
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  facilitatorId   String?
  facilitator     Volunteer?   @relation("FacilitatedGroups", fields: [facilitatorId], references: [id])
  coFacilitatorId String?
  coFacilitator   Volunteer?   @relation("CoFacilitatedGroups", fields: [coFacilitatorId], references: [id])

  // Matching fields (mirrors SmallGroup)
  lifeStageId   String?
  lifeStage     LifeStage?   @relation(fields: [lifeStageId], references: [id])
  genderFocus   GenderFocus?
  language      String[]
  ageRangeMin   Int?
  ageRangeMax   Int?
  meetingFormat MeetingFormat?
  locationCity  String?
  memberLimit   Int?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  members   BreakoutGroupMember[]
  schedules BreakoutGroupSchedule[]
}

model BreakoutGroupSchedule {
  id              String        @id @default(cuid())
  breakoutGroupId String
  breakoutGroup   BreakoutGroup @relation(fields: [breakoutGroupId], references: [id], onDelete: Cascade)
  dayOfWeek       Int           // 0 = Sunday, 6 = Saturday
  timeStart       String        // HH:MM
  timeEnd         String        // HH:MM
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BreakoutGroupMember {
  breakoutGroupId String
  breakoutGroup   BreakoutGroup   @relation(fields: [breakoutGroupId], references: [id], onDelete: Cascade)
  registrantId    String
  registrant      EventRegistrant @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  assignedAt      DateTime        @default(now())

  @@id([breakoutGroupId, registrantId])
}

model VolunteerCommittee {
  id         String    @id @default(cuid())
  name       String
  ministryId String?
  ministry   Ministry? @relation(fields: [ministryId], references: [id])
  eventId    String?
  event      Event?    @relation(fields: [eventId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  roles      CommitteeRole[]
  volunteers Volunteer[]
}

model CommitteeRole {
  id          String             @id @default(cuid())
  name        String
  committeeId String
  committee   VolunteerCommittee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  preferredByVolunteers Volunteer[] @relation("PreferredRole")
  assignedToVolunteers  Volunteer[] @relation("AssignedRole")
}

model Volunteer {
  id              String             @id @default(cuid())
  memberId        String
  member          Member             @relation(fields: [memberId], references: [id])
  ministryId      String?
  ministry        Ministry?          @relation(fields: [ministryId], references: [id])
  eventId         String?
  event           Event?             @relation(fields: [eventId], references: [id])
  committeeId     String
  committee       VolunteerCommittee @relation(fields: [committeeId], references: [id])
  preferredRoleId String
  preferredRole   CommitteeRole      @relation("PreferredRole", fields: [preferredRoleId], references: [id])
  assignedRoleId  String?
  assignedRole    CommitteeRole?     @relation("AssignedRole", fields: [assignedRoleId], references: [id])
  status               VolunteerStatus    @default(Pending)
  notes                String?
  leaderApprovalToken  String?           @unique
  leaderNotes          String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  facilitatedGroups   BreakoutGroup[] @relation("FacilitatedGroups")
  coFacilitatedGroups BreakoutGroup[] @relation("CoFacilitatedGroups")
  busPassengers       BusPassenger[]
}

model MatchingWeightConfig {
  id        String          @id @default(cuid())
  context   MatchingContext @unique
  lifeStage Float
  gender    Float
  language  Float
  age       Float
  schedule  Float
  location  Float
  mode      Float
  career    Float
  capacity  Float
  updatedAt DateTime        @updatedAt
}

// ─── Event Add-on Modules ─────────────────────────────────────────────────────

model EventModule {
  id        String          @id @default(cuid())
  eventId   String
  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type      EventModuleType
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([eventId, type])
}

model BaptismOptIn {
  id           String          @id @default(cuid())
  eventId      String
  event        Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrantId String          @unique  // one baptism per registrant globally (across all events)
  registrant   EventRegistrant @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@unique([eventId, registrantId])
}

model Bus {
  id        String       @id @default(cuid())
  eventId   String
  event     Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  capacity  Int?         // null = unlimited
  direction BusDirection @default(ToVenue)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  passengers BusPassenger[]
}

model BusPassenger {
  id           String           @id @default(cuid())
  busId        String
  bus          Bus              @relation(fields: [busId], references: [id], onDelete: Cascade)
  registrantId String?
  registrant   EventRegistrant? @relation(fields: [registrantId], references: [id], onDelete: Cascade)
  volunteerId  String?
  volunteer    Volunteer?       @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  // Exactly one of registrantId or volunteerId must be set (enforced at app layer)
}
